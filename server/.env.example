# Copia para `.env` na pasta `server/` e ajusta se precisares.
# Compose lê também variáveis do ambiente quando existirem em `.env`.

# --- Infra (portas nos hosts — defaults batem com o docker-compose)
POSTGRES_USER=medkeep
POSTGRES_PASSWORD=medkeep_dev
POSTGRES_DB=medkeep
POSTGRES_PORT=5432

MONGO_USER=medkeep
MONGO_PASSWORD=medkeep_dev
# Se aparecer "port is already allocated" na 27017, muda para outra (ex.: 27018)
# e atualiza MONGO_URI abaixo para localhost:27018
MONGO_PORT=27017

REDIS_PORT=6379

PGADMIN_EMAIL=admin@medkeep.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# --- API Nest (corre na tua máquina, não no container por defeito)
API_PORT=4000
DATABASE_URL=postgresql://medkeep:medkeep_dev@localhost:5432/medkeep
MONGO_URI=mongodb://medkeep:medkeep_dev@localhost:27017/medkeep?authSource=admin
REDIS_URL=redis://localhost:6379

# --- Bot FastAPI
BOT_PORT=8000
